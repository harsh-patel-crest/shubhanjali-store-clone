# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# ─── Storage buckets (defaults shown — change only if you renamed them) ────────
VITE_PRODUCT_BUCKET=products
VITE_CATEGORY_BUCKET=categories

# ─── AI Chat API ──────────────────────────────────────────────────────────────
# URL of the deployed FastAPI chat service (no trailing slash)
# Local dev: http://127.0.0.1:8000
# Production: https://your-chat-api.onrender.com  (or similar)
VITE_CHAT_API_URL=http://127.0.0.1:8000

# ─── App URL (used for canonical links / OG tags) ─────────────────────────────
VITE_APP_URL=https://www.gajanangems.com

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Only the KEY_ID (starts with rzp_test_ or rzp_live_) is needed on the frontend.
# NEVER put your Key Secret here — it must stay server-side only.
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
